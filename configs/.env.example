# trader-bot-web configuration. Copy to configs/.env and edit.
# Only VITE_*-prefixed vars are exposed to client code (Vite policy).

# WebSocket endpoint of portfolio-manager.
# Leave unset to use the same-origin /ws path, which Vite proxies to
# ws://localhost:8081 in dev (see vite.config.js → server.proxy). This
# avoids the same-origin 403 returned by coder/websocket's default
# AcceptOptions when the browser connects directly to :8081.
# Override only if your backend lives on a different host/port AND you
# have configured it to accept the page's Origin.
# VITE_WS_URL=ws://localhost:8081/ws
